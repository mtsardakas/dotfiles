DROP MATERIALIZED VIEW IF EXISTS forecast_app.metadata_materialized CASCADE;CREATE MATERIALIZED VIEW forecast_app.metadata_materialized ASWITH uk_titles AS (    SELECT titles.primary_title_no,           titles.title    FROM intl.titles    WHERE ((titles.ter_id)::text = 'UK'::text)),au_titles AS (    SELECT titles.primary_title_no,           titles.title    FROM intl.titles    WHERE ((titles.ter_id)::text = 'AU'::text)),intl_primary_lang AS (    SELECT DISTINCT ON (primary_title_no, ter_id)           primary_title_no,           ter_id,           (string_to_array(trim(original_language, '{}'), '} {'))[1] AS main_language    FROM intl.releases    WHERE original_language IS NOT NULL    ORDER BY primary_title_no, ter_id, release_no ASC NULLS LAST),intl_lang_counts AS (    SELECT primary_title_no, ter_id, lang, count(*) AS lang_count    FROM intl.releases,         unnest(string_to_array(trim(original_language, '{}'), '} {')) AS lang    WHERE original_language IS NOT NULL    GROUP BY primary_title_no, ter_id, lang),intl_all_langs AS (    SELECT primary_title_no, ter_id, array_agg(lang ORDER BY lang_count DESC, lang) AS all_languages    FROM intl_lang_counts    GROUP BY primary_title_no, ter_id),intl_original_language AS (    SELECT p.primary_title_no,           p.ter_id,           ARRAY[p.main_language] || array_remove(a.all_languages, p.main_language) AS original_language    FROM intl_primary_lang p    JOIN intl_all_langs a USING (primary_title_no, ter_id)),dom_primary_lang AS (    SELECT DISTINCT ON (primary_title_no)           primary_title_no,           (string_to_array(trim(original_language, '{}'), '} {'))[1] AS main_language    FROM dom.releases    WHERE original_language IS NOT NULL    ORDER BY primary_title_no, release_date ASC NULLS LAST),dom_lang_counts AS (    SELECT primary_title_no, lang, count(*) AS lang_count    FROM dom.releases,         unnest(string_to_array(trim(original_language, '{}'), '} {')) AS lang    WHERE original_language IS NOT NULL    GROUP BY primary_title_no, lang),dom_all_langs AS (    SELECT primary_title_no, array_agg(lang ORDER BY lang_count DESC, lang) AS all_languages    FROM dom_lang_counts    GROUP BY primary_title_no),dom_original_language AS (    SELECT p.primary_title_no,           ARRAY[p.main_language] || array_remove(a.all_languages, p.main_language) AS original_language    FROM dom_primary_lang p    JOIN dom_all_langs a USING (primary_title_no)),dom_titles AS (    SELECT titles.ter_id,           titles.primary_title_no,           xref.iboe_title_no AS intl_primary_title_no,           titles.release_date,           titles.distributor_id,           titles.distributor,           titles.actors,           titles.directors,           titles.title,           titles.rating,           titles.primary_genre_id,           titles.title AS international_title,           (titles.actors || titles.directors) AS talent,           dol.original_language    FROM (dom.titles        LEFT JOIN common.xref xref ON ((titles.primary_title_no = xref.boe_title_no)))        LEFT JOIN dom_original_language dol ON (dol.primary_title_no = titles.primary_title_no)    WHERE (((titles.ter_id)::text = 'DOM'::text)        AND (titles.release_date IS NOT NULL)        AND (titles.title IS NOT NULL))),intl_titles AS (    SELECT intl.ter_id,           intl.primary_title_no,           intl.release_date,           intl.distributor_id,           intl.distributor,           intl.actors,           intl.directors,           intl.title,           intl.rating,           intl.primary_genre_id,           COALESCE(dom.title, uk.title, au.title) AS international_title,           (intl.actors || intl.directors) AS talent,           ol.original_language    FROM (((intl.titles intl        LEFT JOIN dom_titles dom ON ((dom.intl_primary_title_no = intl.primary_title_no)))        LEFT JOIN uk_titles uk ON ((uk.primary_title_no = intl.primary_title_no)))        LEFT JOIN au_titles au ON ((au.primary_title_no = intl.primary_title_no)))        LEFT JOIN intl_original_language ol ON (ol.primary_title_no = intl.primary_title_no AND ol.ter_id = intl.ter_id)    WHERE ((intl.release_date IS NOT NULL)        AND ((intl.ter_id)::text <> ALL (ARRAY[('US'::character varying)::text, ('CA'::character varying)::text, ('PR'::character varying)::text]))        AND (intl.title IS NOT NULL)))SELECT intl_titles.ter_id,       intl_titles.primary_title_no,       intl_titles.release_date,       intl_titles.distributor_id,       intl_titles.distributor,       intl_titles.actors,       intl_titles.directors,       intl_titles.title,       intl_titles.rating,       intl_titles.primary_genre_id,       intl_titles.international_title,       intl_titles.talent,       intl_titles.original_languageFROM intl_titlesUNIONSELECT dom_titles.ter_id,       dom_titles.primary_title_no,       dom_titles.release_date,       dom_titles.distributor_id,       dom_titles.distributor,       dom_titles.actors,       dom_titles.directors,       dom_titles.title,       dom_titles.rating,       dom_titles.primary_genre_id,       dom_titles.international_title,       dom_titles.talent,       dom_titles.original_languageFROM dom_titles;ALTER MATERIALIZED VIEW forecast_app.metadata_materialized OWNER TO rentrakfeed;CREATE UNIQUE INDEX idx_metadata_ptn_ter_id ON forecast_app.metadata_materialized USING btree (primary_title_no, ter_id);CREATE INDEX idx_metadata_release_date ON forecast_app.metadata_materialized USING btree (release_date);CREATE INDEX idx_metadata_search ON forecast_app.metadata_materialized USING gin (to_tsvector('public.no_accent'::regconfig, title));CREATE INDEX idx_metadata_ter_release_covering ON forecast_app.metadata_materialized USING btree (ter_id, release_date, primary_title_no) INCLUDE (distributor_id, distributor, rating, title, talent, international_title);GRANT SELECT ON TABLE forecast_app.metadata_materialized TO clientreadonly, cronicle, metabase, forecast, domatlas, expertsense, dagster;-- forecast_app.metadata view (adds primary_genre_id; title override logic unchanged)CREATE VIEW forecast_app.metadata ASSELECT    mm.ter_id,    mm.primary_title_no,    mm.release_date,    mm.distributor_id,    mm.distributor,    mm.actors,    mm.directors,    mm.title,    mm.rating,    mm.primary_genre_id,    mm.original_language,    COALESCE(        oto_dom.title_override,        oto_intl.title_override,        mm.international_title    ) AS international_title,    mm.talent,    mm.international_title AS original_international_titleFROM forecast_app.metadata_materialized mmLEFT JOIN overrides.title_overrides AS oto_dom    ON mm.ter_id = 'DOM'   AND oto_dom.dom_primary_title_no = mm.primary_title_noLEFT JOIN overrides.title_overrides AS oto_intl    ON mm.ter_id <> 'DOM'   AND oto_intl.intl_primary_title_no = mm.primary_title_no;ALTER VIEW forecast_app.metadata OWNER TO postgres;GRANT SELECT ON TABLE forecast_app.metadata TO clientreadonly, cronicle, metabase, forecast, domatlas, expertsense, dagster;-- Recreate forecast_app.wknd (CASCADE dropped it; definition unchanged)CREATE VIEW forecast_app.wknd AS WITH last_week AS (         SELECT dailies.ter_id,            dailies.primary_title_no,            dailies.wknd_report_sunday,            sum(dailies.value) AS last_wknd,            max(dailies.cume) AS last_wknd_cume           FROM forecast_app.dailies          WHERE (((dailies.currency)::text = 'USD'::text) AND (dailies.type = ANY (ARRAY[2, 4])) AND dailies.is_weekend)          GROUP BY dailies.ter_id, dailies.primary_title_no, dailies.wknd_report_sunday        ), week AS (         SELECT dailies.ter_id,            dailies.primary_title_no,            dailies.wknd_report_sunday,            min(dailies.week) AS week,            max(dailies.film_week) AS film_week,            sum(dailies.value) FILTER (WHERE dailies.is_weekend) AS wknd,            jsonb_object_agg(to_char((dailies.date)::timestamp with time zone, 'Dy'::text), dailies.value) AS dailies,            max(dailies.cume) AS cume           FROM forecast_app.dailies          WHERE (((dailies.currency)::text = 'USD'::text) AND (dailies.type = ANY (ARRAY[2, 4])))          GROUP BY dailies.ter_id, dailies.primary_title_no, dailies.wknd_report_sunday        ), lifetimes AS (         SELECT dailies.ter_id,            dailies.primary_title_no,            dailies.cume AS base           FROM forecast_app.dailies          WHERE (dailies.is_lifetime AND ((dailies.currency)::text = 'USD'::text) AND (dailies.type = ANY (ARRAY[2, 4])))        ) SELECT row_number() OVER (PARTITION BY week.wknd_report_sunday, week.ter_id ORDER BY COALESCE(week.wknd, (0)::double precision) DESC) AS rank,    week.ter_id,    territory.region,    week.primary_title_no,    week.wknd,    last_week.last_wknd,    week.cume,    last_week.last_wknd_cume,    (COALESCE((week.dailies ->> 'Mon'::text), '0'::text))::numeric AS mon,    (COALESCE((week.dailies ->> 'Tue'::text), '0'::text))::numeric AS tue,    (COALESCE((week.dailies ->> 'Wed'::text), '0'::text))::numeric AS wed,    (COALESCE((week.dailies ->> 'Thu'::text), '0'::text))::numeric AS thu,    (COALESCE((week.dailies ->> 'Fri'::text), '0'::text))::numeric AS fri,    (COALESCE((week.dailies ->> 'Sat'::text), '0'::text))::numeric AS sat,    (COALESCE((week.dailies ->> 'Sun'::text), '0'::text))::numeric AS sun,    COALESCE(lifetimes.base, (0)::double precision) AS life,    concat('(', array_to_string(ARRAY[        CASE WHEN (territory.wknd_start_day = 1) THEN 'Mon'::text ELSE NULL::text END,        CASE WHEN (territory.wknd_start_day <= 2) THEN 'Tue'::text ELSE NULL::text END,        CASE WHEN (territory.wknd_start_day <= 3) THEN 'Wed'::text ELSE NULL::text END,        CASE WHEN (territory.wknd_start_day <= 4) THEN 'Thu'::text ELSE NULL::text END,        CASE WHEN (territory.wknd_start_day <= 5) THEN 'Fri'::text ELSE NULL::text END,        CASE WHEN (territory.wknd_start_day <= 6) THEN 'Sat'::text ELSE NULL::text END,        CASE WHEN (territory.wknd_start_day <= 7) THEN 'Sun'::text ELSE NULL::text END    ], ', '::text), ')') AS days_in_weekend,    week.week AS weeks_out,    week.film_week AS wk,    week.wknd_report_sunday,    territory.country_name AS terr_name,    metadata.international_title,    metadata.title,    metadata.distributor,    metadata.rating,    metadata.release_date   FROM (((((week     LEFT JOIN last_week ON (((last_week.wknd_report_sunday = (week.wknd_report_sunday - 7)) AND (last_week.primary_title_no = week.primary_title_no) AND ((last_week.ter_id)::text = (week.ter_id)::text))))     JOIN lifetimes ON ((((lifetimes.ter_id)::text = (week.ter_id)::text) AND (lifetimes.primary_title_no = week.primary_title_no))))     JOIN forecast_app.metadata ON ((((metadata.ter_id)::text = (week.ter_id)::text) AND (metadata.primary_title_no = week.primary_title_no))))     JOIN common.territory_group ON (((week.ter_id)::text = territory_group.ter_id)))     JOIN common.territory ON ((territory.country_code = (week.ter_id)::text)))  WHERE ((territory_group.id)::text = 'GLOBAL'::text);ALTER VIEW forecast_app.wknd OWNER TO postgres;GRANT SELECT ON TABLE forecast_app.wknd TO clientreadonly, cronicle, metabase, forecast, domatlas, dagster;-- Recreate forecast_app.ffwd (CASCADE dropped it; definition unchanged)CREATE OR REPLACE VIEW forecast_app.ffwd AS WITH xref AS (         SELECT xref.iboe_title_no AS intl_primary_title_no,            xref.boe_title_no AS dom_primary_title_no,            xref.booking_xref_title_no AS booking_id,            xref.iboe_name AS international_title           FROM common.xref        ), xref_long AS (         SELECT x_1.booking_id,            x_1.intl_primary_title_no AS primary_title_no,            'True'::text AS is_intl           FROM xref x_1        UNION         SELECT x_1.booking_id,            x_1.dom_primary_title_no AS primary_title_no,            'False'::text AS is_intl           FROM xref x_1        ), intl_releases AS (         SELECT m.primary_title_no,            mode() WITHIN GROUP (ORDER BY m.release_date) AS most_common_int_rdate,            x_1.booking_id           FROM (forecast_app.metadata m             JOIN xref x_1 ON ((m.primary_title_no = x_1.intl_primary_title_no)))          WHERE ((m.ter_id)::text <> ALL (ARRAY[('DOM'::character varying)::text, ('US'::character varying)::text, ('CA'::character varying)::text, ('PR'::character varying)::text]))          GROUP BY m.primary_title_no, x_1.booking_id        ), dom_releases AS (         SELECT m.primary_title_no AS dom_primary_title_no,            m.release_date AS dom_rdate,            x_1.booking_id           FROM (forecast_app.metadata m             JOIN xref x_1 ON ((m.primary_title_no = x_1.dom_primary_title_no)))          WHERE ((m.ter_id)::text = 'DOM'::text)        ), films_in_scope AS (         SELECT i_1.booking_id           FROM intl_releases i_1          WHERE (i_1.most_common_int_rdate >= (CURRENT_DATE - '6 mons'::interval))        UNION         SELECT d_1.booking_id           FROM dom_releases d_1          WHERE (d_1.dom_rdate >= (CURRENT_DATE - '6 mons'::interval))        ), dailies_gbo AS (         SELECT d_1.primary_title_no,            d_1.ter_id,                CASE                    WHEN ((d_1.ter_id)::text <> 'DOM'::text) THEN 'True'::text                    ELSE 'False'::text                END AS is_intl,            max(d_1.cume) AS gross           FROM forecast_app.dailies d_1          WHERE (((d_1.currency)::text = 'USD'::text) AND (d_1.type = ANY (ARRAY[2, 4])) AND d_1.is_lifetime)          GROUP BY d_1.primary_title_no, d_1.ter_id        ), dailies_with_booking AS (         SELECT xl.booking_id,            dg.ter_id,            dg.gross           FROM (dailies_gbo dg             JOIN xref_long xl ON (((dg.primary_title_no = xl.primary_title_no) AND (dg.is_intl = xl.is_intl))))        ), gbo_split AS (         SELECT dwb.booking_id,            max(CASE WHEN ((dwb.ter_id)::text = 'DOM'::text) THEN dwb.gross ELSE NULL::double precision END) AS dom_gbo_fcast,            max(CASE WHEN ((dwb.ter_id)::text = 'CN'::text) THEN dwb.gross ELSE NULL::double precision END) AS cn_gbo_fcast,            sum(CASE WHEN ((dwb.ter_id)::text <> ALL (ARRAY[('DOM'::character varying)::text, ('CN'::character varying)::text])) THEN dwb.gross ELSE NULL::double precision END) AS int_gbo_fcast_ex_cn           FROM dailies_with_booking dwb          GROUP BY dwb.booking_id        ), top_gbo_ranked AS (         SELECT dwb.booking_id,            dwb.ter_id,            row_number() OVER (PARTITION BY dwb.booking_id ORDER BY dwb.gross DESC) AS rn           FROM dailies_with_booking dwb          WHERE ((dwb.ter_id)::text <> 'DOM'::text)        ), top_ter AS (         SELECT top_gbo_ranked.booking_id,            top_gbo_ranked.ter_id AS top_ter_id           FROM top_gbo_ranked          WHERE (top_gbo_ranked.rn = 1)        ), top_metadata AS (         SELECT t.booking_id,            m.title AS top_title,            m.distributor AS top_distributor,            m.rating AS top_rating,            m.release_date AS top_rdate,            actor_names.actor_names AS top_cast_names,            director_names.director_names AS top_director,            s.synopsis AS top_synopsis           FROM (((((top_ter t             JOIN xref x_1 ON ((t.booking_id = x_1.booking_id)))             JOIN intl.synopses s ON (((s.primary_title_no = x_1.intl_primary_title_no) AND ((s.ter_id)::text = (t.top_ter_id)::text))))             JOIN forecast_app.metadata m ON (((m.primary_title_no = x_1.intl_primary_title_no) AND ((m.ter_id)::text = (t.top_ter_id)::text))))             LEFT JOIN LATERAL ( SELECT string_agg((tal.name)::text, ', '::text) AS actor_names                   FROM intl.talent tal                  WHERE (tal.id = ANY (m.actors))) actor_names ON (true))             LEFT JOIN LATERAL ( SELECT string_agg((tal.name)::text, ', '::text) AS director_names                   FROM intl.talent tal                  WHERE (tal.id = ANY (m.directors))) director_names ON (true))        ), dom_meta AS (         SELECT x_1.booking_id,            m.title AS dom_title,            m.distributor AS dom_distributor,            m.rating AS dom_rating,            m.release_date AS dom_rdate,            actor_names.actor_names AS dom_cast_names,            director_names.director_names AS dom_director           FROM (((xref x_1             JOIN forecast_app.metadata m ON (((m.primary_title_no = x_1.dom_primary_title_no) AND ((m.ter_id)::text = 'DOM'::text))))             LEFT JOIN LATERAL ( SELECT string_agg((tal.name)::text, ', '::text) AS actor_names                   FROM dom.talent tal                  WHERE (tal.person_no = ANY (m.actors))) actor_names ON (true))             LEFT JOIN LATERAL ( SELECT string_agg((tal.name)::text, ', '::text) AS director_names                   FROM dom.talent tal                  WHERE (tal.person_no = ANY (m.directors))) director_names ON (true))        ), dom_synopsis AS (         SELECT x_1.booking_id,            s.synopsis AS dom_synopsis           FROM (xref x_1             JOIN dom.synopses s ON ((s.primary_title_no = x_1.dom_primary_title_no)))        ) SELECT x.booking_id,    x.intl_primary_title_no,    x.dom_primary_title_no,    x.international_title,    i.most_common_int_rdate,    tt.top_ter_id,    tm.top_title,    tm.top_distributor,    tm.top_rdate,    tm.top_rating,    tm.top_synopsis,    tm.top_cast_names,    tm.top_director,    dm.dom_title,    dm.dom_distributor,    dm.dom_rdate,    dm.dom_rating,    ds.dom_synopsis,    dm.dom_cast_names,    dm.dom_director,    g.dom_gbo_fcast,    g.cn_gbo_fcast,    g.int_gbo_fcast_ex_cn,    ((COALESCE(g.dom_gbo_fcast, (0)::double precision) + COALESCE(g.cn_gbo_fcast, (0)::double precision)) + COALESCE(g.int_gbo_fcast_ex_cn, (0)::double precision)) AS total_gbo   FROM ((((((((films_in_scope f     JOIN xref x ON ((f.booking_id = x.booking_id)))     LEFT JOIN intl_releases i ON ((f.booking_id = i.booking_id)))     LEFT JOIN dom_releases d ON ((f.booking_id = d.booking_id)))     LEFT JOIN top_ter tt ON ((f.booking_id = tt.booking_id)))     LEFT JOIN top_metadata tm ON ((f.booking_id = tm.booking_id)))     LEFT JOIN gbo_split g ON ((f.booking_id = g.booking_id)))     LEFT JOIN dom_meta dm ON ((f.booking_id = dm.booking_id)))     LEFT JOIN dom_synopsis ds ON ((f.booking_id = ds.booking_id)));ALTER VIEW forecast_app.ffwd OWNER TO postgres;GRANT SELECT ON TABLE forecast_app.ffwd TO dagster, forecast, mathesar, metabase, cronicle;REFRESH MATERIALIZED VIEW forecast_app.metadata_materialized;

CREATE TABLE IF NOT EXISTS analyst.holidays (    ter_id              text        NOT NULL,    day                 date        NOT NULL,    holiday_name        text        NOT NULL,    holiday_type        text,    confidence_perc     integer,    pop_affected_perc   integer,    comment             text,    updated_at          timestamptz NOT NULL DEFAULT now(),    consolidator_output jsonb,    UNIQUE (ter_id, day, holiday_name));ALTER TABLE analyst.holidays OWNER TO cronicle;GRANT SELECT ON analyst.holidays TO forecast;GRANT SELECT ON analyst.holidays TO metabase;GRANT SELECT ON analyst.holidays TO dagster;
CREATE TABLE IF NOT EXISTS analyst.holidays (    ter_id              text        NOT NULL,    day                 date        NOT NULL,    holiday_name        text        NOT NULL,    holiday_type        text,    confidence_perc     integer,    pop_affected_perc   integer,    comment             text,    updated_at          timestamptz NOT NULL DEFAULT now(),    consolidator_output jsonb,    UNIQUE (ter_id, day, holiday_name));ALTER TABLE analyst.holidays OWNER TO cronicle;GRANT SELECT ON analyst.holidays TO forecast;GRANT SELECT ON analyst.holidays TO metabase;GRANT SELECT ON analyst.holidays TO dagster;
